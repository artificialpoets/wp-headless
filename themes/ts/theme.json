{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "base",       "name": "Base",       "color": "#ffffff" },
        { "slug": "contrast",   "name": "Contrast",   "color": "#111111" },
        { "slug": "accent-1",   "name": "Accent 1",   "color": "#ffee58" },
        { "slug": "accent-2",   "name": "Accent 2",   "color": "#f6cff4" },
        { "slug": "accent-3",   "name": "Accent 3",   "color": "#503aa8" },
        { "slug": "accent-4",   "name": "Accent 4",   "color": "#686868" },
        { "slug": "accent-5",   "name": "Accent 5",   "color": "#fbfaf3" }
      ]
    },
    "typography": {
      "fontSizes": [
        { "slug": "small",   "name": "Small",   "size": "0.875rem" },
        { "slug": "medium",  "name": "Medium",  "size": "1.0625rem" },
        { "slug": "large",   "name": "Large",   "size": "1.25rem" },
        { "slug": "x-large", "name": "X-Large", "size": "1.5625rem" }
      ],
      "fontFamilies": [
        { "slug": "body",    "name": "Body",    "fontFamily": "system-ui, -apple-system, 'Segoe UI', sans-serif" },
        { "slug": "heading", "name": "Heading", "fontFamily": "ui-serif, Georgia, 'Times New Roman', serif" },
        { "slug": "mono",    "name": "Mono",    "fontFamily": "ui-monospace, 'Cascadia Code', 'Fira Code', monospace" }
      ]
    },
    "spacing": {
      "spacingSizes": [
        { "slug": "20", "name": "2X-Small", "size": "0.5rem" },
        { "slug": "30", "name": "X-Small",  "size": "1rem" },
        { "slug": "40", "name": "Small",    "size": "1.5rem" },
        { "slug": "50", "name": "Medium",   "size": "2rem" },
        { "slug": "60", "name": "Large",    "size": "3rem" },
        { "slug": "70", "name": "X-Large",  "size": "5rem" }
      ]
    },
    "layout": {
      "contentSize": "52rem",
      "wideSize":    "80rem"
    }
  }
}
