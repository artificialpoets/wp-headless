# =====================================================================
# wp-headless .gitignore
#
# Pre-wp.org strategy: we self-host updates via GitHub Releases, so the
# committed repo IS the distribution artifact. That means we COMMIT:
#   - vendor/   → runtime PHP deps (plugin-update-checker etc.)
#   - themes/*/dist/  → prebuilt React frontend (so sites work out of the box)
# Once on wp.org we can revisit and rely on the build pipeline instead.
# =====================================================================

# PHP — dev artifacts only. vendor/ IS committed.
.phpunit.cache/
composer.phar

# Node / Vite — committed: themes/*/dist (built). Ignored: source build state.
node_modules/
themes/js/node_modules/
themes/ts/node_modules/
themes/*/.vite/

# Build / IDE
*.log
.idea/
.vscode/
*.swp
.DS_Store

# Local dev artifacts — ignore the running WP installs, keep the scaffold
dev/three-sites/.runtime/
*.local
.env
.env.*
!.env.example

# Translations build artifacts
languages/*.mo
languages/*.po~

# Release zip (built by CI, never commit by hand)
/build/
/wp-headless.zip

# OS
Thumbs.db
